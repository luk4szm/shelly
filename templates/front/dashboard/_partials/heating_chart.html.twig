<div class="card card-sm">
    <div class="card-body mb-0">
        <div class="row">
            <div class="col px-0">
                <div id="heating_simple_chart" class="position-relative"></div>
            </div>
            <div class="col-md-auto">
                <div class="divide-y divide-y-fill">
                    <div class="px-3">
                        <div class="text-secondary">Energia</div>
                        <div class="h2 mb-0">
                            {{ buffer.energy|number_format(1) }} kWh
                        </div>
                        <div class="fs-4">equiv. {{ (buffer.energy/9.45)|number_format(1) }} m³</div>
                    </div>
                    <div class="px-3">
                        <div class="text-secondary"><span class="status-dot" style="background-color: #D63939"></span> Bufor 1.5m</div>
                        <div class="h2">{{ buffer.temperature_15m.value|number_format(1) }} °C</div>
                    </div>
                    <div class="px-3">
                        <div class="text-secondary"><span class="status-dot" style="background-color: #F76707"></span> Bufor 0.5m</div>
                        <div class="h2">{{ buffer.temperature_05m.value|number_format(1) }} °C</div>
                    </div>
                    <div class="px-3">
                        <div class="text-secondary">Ciśnienie</div>
                        <div class="h2">{{ (buffer.pressure.value/100)|number_format(2) }} bar</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
