{% extends 'base.html.twig' %}

{% block customCss %}
    <style>
       /* CSS */
       .no-scrollbar {
          overflow-y: auto; /* przewijanie włączone */
          -webkit-overflow-scrolling: touch; /* płynne przewijanie na iOS */
          scrollbar-width: none; /* Firefox: ukryj pasek */
          -ms-overflow-style: none; /* Stare IE/Edge: ukryj pasek */
       }

       /* WebKit (Chrome, Safari, Edge Chromium): ukryj pasek */
       .no-scrollbar::-webkit-scrollbar {
          width: 0;
          height: 0;
          display: none;
       }

       .device-status-item {
          width: 100%;
       }

       @media (min-width: 768px) {
          .device-status-item {
             width: 50%;
          }
       }

       @media (min-width: 1200px) {
          .device-status-item {
             width: 25%;
          }

          .device-status-grid-1 .device-status-item,
          .device-status-grid-2 .device-status-item,
          .device-status-grid-3 .device-status-item,
          .device-status-grid-4 .device-status-item {
             flex: 1 0 0;
             width: auto;
          }

          .device-status-grid-5 .device-status-item {
             width: 33.333333%;
          }

          .device-status-grid-5 .device-status-item:nth-child(4) {
             margin-left: 16.666667%;
          }
       }
    </style>
{% endblock %}

{% block pageBody %}
    <div class="container-xl">
        {% set currentHour = "now"|date('H')|number_format %}
        {% if occupancy == constant('App\\Enum\\OccupancyMode::Sleeping').value %}
            {% if currentHour >= 4 and currentHour < 20 %}
                {{ _self.scene_button("waking", "Pobudka") }}
            {% endif %}
        {% endif %}
        {% if occupancy == constant('App\\Enum\\OccupancyMode::Away').value %}
            {{ _self.scene_button("coming", "Wracam do domu") }}
        {% endif %}
        {% if occupancy == constant('App\\Enum\\OccupancyMode::Home').value %}
            {% if currentHour >= 23 or currentHour < 4 %}
                {{ _self.scene_button("sleeping", "Idziemy spać") }}
            {% endif %}
        {% endif %}
        <div class="row row-deck row-cards align-items-stretch">
            <div class="col-md-4 col-12 d-inline">
                {% include 'front/dashboard/_partials/weather.html.twig' %}
                {% if season != constant('App\\Enum\\SeasonMode::Summer').value %}
                    {% include 'front/dashboard/_partials/heating_controllers.html.twig' %}
                {% endif %}
            </div>
            <div class="col-md-8 col-12 d-none d-md-flex">
                {% include 'front/dashboard/_partials/heating_chart.html.twig' %}
            </div>
        </div>
    </div>
    {% if occupancy != constant('App\\Enum\\OccupancyMode::Vacation').value %}
        <div id="devices_controllers" class="container-xl mt-3">
            <div class="row row-deck row-cards">
                {% include 'front/dashboard/_partials/device_controllers.html.twig' %}
            </div>
        </div>
    {% endif %}
    <div id="reloadable-box">
        <div id="devices_status" class="container-xl mt-3" data-device-names="{{ devices|map((device) => device.name)|join('|') }}">
            <div class="row row-cards device-status-grid-{{ devices|length }}">
                {% include 'front/dashboard/_partials/device_status.html.twig' %}
            </div>
        </div>
        <div id="temperatures_card" class="container-xl mt-3">
            <div class="row row-deck row-cards">
                {% include 'front/dashboard/_partials/location_temperatures.html.twig' %}
            </div>
        </div>
    </div>
{% endblock %}

{% block modals %}
    {% include 'front/_modals/heating_controller_modal.html.twig' with {'isHeatingActive': heatingPump.supply.active and heatingPump.return.active} %}
    {% include 'front/_modals/wheather_table_modal.html.twig' %}
    {% include 'front/_modals/wheather_meteogram_modal.html.twig' %}
    {% include 'front/_modals/wheather_card_modal.html.twig' %}
{% endblock %}

{% block pagejs %}
    <script src="{{ asset('js/device_status.js') }}"></script>
    <script src="{{ asset('js/device_control.js') }}?v=20260706"></script>
    <script src="{{ asset('js/location_temperatures.js') }}"></script>
    <script src="{{ asset('js/heating_simple_chart.js') }}?v=20260601"></script>
    <script src="{{ asset('js/heating_modal.js') }}"></script>
{% endblock %}

{% macro scene_button(action, label, controller = 'scene', map_hash = null) %}
    <div class="row d-md-none mb-3 scene-hideable-div">
        <div class="col-12">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <button class="btn btn-azure btn-5 long-press-btn w-100"
                                    data-controller="{{ controller }}"
                                    data-action="{{ action }}"
                                    {% if map_hash %}data-map-hash="{{ map_hash }}"{% endif %}>
                                <span>{{ label }}</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="scene-controller-status"></div>
        </div>
    </div>
{% endmacro %}
