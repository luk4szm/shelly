{% extends 'base.html.twig' %}

{% block pageTitle %}Nawadnianie{% endblock %}
{% block pagePreTitle %}{% endblock %}
{% block pageTitleActions %}{% endblock %}

{% block customCss %}
    <style>
        .sortable-ghost {
            background-color: var(--tblr-bg-surface-light) !important;
            opacity: 0.6;
        }
        .cursor-grab {
            cursor: grab;
        }
        .cursor-grab:active {
            cursor: grabbing;
        }

        .remove-valve {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            width: 2rem;
            height: 2rem;
        }

        .remove-valve svg {
            margin: 0 !important;
        }
    </style>
{% endblock %}

{% block pageBody %}
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12 col-md-3">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-6">
                                <div class="subheader mb-2">
                                    <span class="text-secondary">Temperatura</span>
                                </div>
                                <a class="h1 mb-0 text-reset text-decoration-none"
                                   href="{{ path('app_front_default_location_daily', {'location': 'ogrod'}) }}">
                                    {{ soil.temp.value|number_format(1) }} °C
                                </a>
                            </div>
                            <div class="col-6 text-end">
                                <div class="subheader mb-2">
                                    <span class="text-secondary">Wilgotność</span>
                                </div>
                                <a class="h1 mb-0 text-reset text-decoration-none"
                                   href="{{ path('app_front_default_location_daily', {'location': 'ogrod'}) }}">
                                    {{ soil.humidity.value|number_format(1) }} %
                                </a>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-6">
                                <div class="subheader mb-2">
                                    <span class="text-secondary">Opad 24h</span>
                                    {% if precipitation.last24h.sum > 0 %}
                                        <small class="my-0 text-muted">{{ precipitation.last24h.lastAt|date('H:i') }}</small>
                                    {% endif %}
                                </div>
                                <div class="h1 mb-0 {{ precipitation.last24h.sum ? 'text-azure' : 'text-muted' }}">
                                    {{ precipitation.last24h.sum|number_format(1) }} mm
                                </div>
                            </div>
                            <div class="col-6 text-end">
                                <div class="subheader mb-2">
                                    {% if precipitation.forecast.sum > 0 %}
                                        <small class="my-0 text-muted">{{ precipitation.last24h.lastAt|date('H:i') }}</small>
                                    {% endif %}
                                    <span class="text-secondary">Prognoza</span>
                                </div>
                                <div class="h1 mb-0 {{ precipitation.forecast.sum ? 'text-azure' : 'text-muted' }}">
                                    {{ precipitation.forecast.sum|number_format(1) }} mm
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Szybkie nawadnianie</h3>
                    </div>
                    <div class="card-body">
                        <form id="valve_quick_run" method="post" action="{{ path('app_front_hydration_save_schedule') }}">
                            <div id="valves-sortable">
                                {% for valve in valves %}
                                    <div class="row mb-1 valve-row cursor-grab">
                                        <label for="{{ valve.name }}_duration" class="col d-flex align-items-center">
                                            <span class="me-2 text-muted drag-handle" style="cursor: move;">☰</span>
                                            {{ valve.name|trans }}
                                        </label>
                                        <div class="col-auto">
                                            <div class="input-group">
                                                <button class="btn" type="button" id="{{ valve.name }}_less" title="Skróć czas podlewania" style="width: 20px">&#8592;</button>
                                                <select class="form-select text-center" id="{{ valve.name }}_duration" name="{{ valve.name }}" style="width: 45px; appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: none; padding-right: 0.5rem; padding-left: 0.5rem;">
                                                    {% set defaultValue = (valve.name == 'hydration_valve_rotating' ? 40 : 15) %}
                                                    {% for i in 0..60 %}
                                                        <option value="{{ i }}" {{ i == defaultValue ? 'selected' : '' }}>{{ i }}</option>
                                                    {% endfor %}
                                                </select>
                                                <button class="btn" type="button" id="{{ valve.name }}_more" title="Wydłuż czas podlewania" style="width: 20px">&#8594;</button>
                                            </div>
                                        </div>
                                        <div class="col-auto px-0">
                                            <button type="button" class="btn btn-action remove-valve" title="Usuń sekcję">
                                                {{ include('_icons/x-icon.svg.twig') }}
                                            </button>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                            <div class="mb-3 mt-3 row">
                                <label class="col-3 col-form-label" for="hydration_start_time">Start</label>
                                <div class="col">
                                    <input type="datetime-local" class="form-control text-center" id="hydration_start_time"
                                           name="hydration_start_time" min="{{ "now"|date('Y-m-d H:i') }}"/>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-azure w-100 mt-2">Uruchom sekwencję</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-9 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Plan nawodnień</h3>
                    </div>
                    {% if hydrationPlan is not empty %}
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                <tr>
                                    <th class="w-1">Strefa</th>
                                    <th class="w-100 d-none d-md-table-cell">Progress</th>
                                    <th class="text-center">Start</th>
                                    <th class="text-center">Czas</th>
                                    <th class="text-center">Koniec</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for state in hydrationPlan %}
                                    <tr style="position: relative;">
                                        <td class="text-nowrap">
                                            {{ state.valve|trans }}
                                            {# Progress bar widoczny TYLKO na mobile, jako cienka linia pod wierszem #}
                                            <div class="progress progress-sm d-md-none"
                                                 style="position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; border-radius: 0; background: transparent;">
                                                {{ _self.progress_bar(state) }}
                                            </div>
                                        </td>
                                        <td class="text-secondary d-none d-md-table-cell">
                                            <div class="progress">
                                                {{ _self.progress_bar(state) }}
                                            </div>
                                        </td>
                                        <td class="text-secondary text-center">
                                            {% set startDateTime = (state.startsAt ?? state.scheduledStartAt) %}
                                            {% if startDateTime|date('Y-m-d') != "now"|date('Y-m-d') %}
                                                {{ startDateTime|date('d.m.Y') }}<br>
                                            {% endif %}
                                            {{ startDateTime|date('H:i:s') }}
                                        </td>
                                        <td class="text-secondary text-center text-nowrap">
                                            <span class="progress-text">
                                                0%<br>
                                                {% if state.duration %}
                                                    {{ (state.duration // 60) }}:{{ (state.duration % 60)|format('%02d') }}
                                                {% else %}
                                                    --:--
                                                {% endif %}
                                            </span>
                                        </td>
                                        <td class="text-secondary text-center">
                                            {% set endDateTime = (state.endsAt ?? state.scheduledEndAt) %}
                                            {% if endDateTime and endDateTime|date('Y-m-d') != "now"|date('Y-m-d') %}
                                                {{ endDateTime|date('d.m.Y') }}<br>
                                            {% endif %}
                                            {{ endDateTime ? endDateTime|date('H:i:s') : '' }}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="card-body">
                            <p class="text-secondary text-center">
                                Nie znaleziono żadnych bieżących, planowanych, ani zakończonych w ostatnich 24 godzinach nawodnień.
                            </p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% macro progress_bar(state) %}
    <div class="progress-bar {% if state.duration %}progress-bar-striped progress-bar-animated{% else %}progress-bar-indeterminate{% endif %}"
        {% if state.duration %}
            style="width: {{ state.calculateActualProgress > 0
                ? (state.calculateActualProgress / state.duration) * 100
                : 0
            }}%"
         {% endif %}
         data-start-time="{{ (state.startsAt ?? state.scheduledStartAt)|date('c') }}"
         data-end-time="{{ state.scheduledEndAt ? state.scheduledEndAt|date('c') }}"
         data-duration="{{ state.duration ?? 0 }}"
         data-actual-progress="{{ state.calculateActualProgress }}"
    ></div>
{% endmacro %}

{% block pagejs %}
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script src="{{ asset('js/hydration/hydration-quick-run.js') }}"></script>
    <script src="{{ asset('js/hydration/hydration-schedule.js') }}"></script>
{% endblock %}
