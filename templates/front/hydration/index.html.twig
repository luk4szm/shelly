{% extends 'base.html.twig' %}

{% block pageTitle %}Nawadnianie{% endblock %}
{% block pagePreTitle %}{% endblock %}
{% block pageTitleActions %}{% endblock %}

{% block pageBody %}
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12 col-md-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Szybkie nawadnianie</h3>
                    </div>
                    <div class="card-body">
                        <form id="valve_quick_run" method="post" action="{{ path('app_front_hydration_save_schedule') }}">
                            {% for valve in valves %}
                                <div class="row mb-1">
                                    <label for="{{ valve.name }}_duration" class="col d-flex align-items-center">
                                        {{ valve.name|trans }}
                                    </label>
                                    <div class="col-auto">
                                        <div class="input-group">
                                            <button class="btn" type="button" id="{{ valve.name }}_less" title="Skróć czas podlewania" style="width: 20px">&#8592;</button>
                                            <select class="form-select text-center" id="{{ valve.name }}_duration" name="{{ valve.name }}" style="width: 45px; appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: none; padding-right: 0.5rem; padding-left: 0.5rem;">
                                                {% set defaultValue = (valve.name == 'hydration_valve_rotating' ? 40 : 15) %}
                                                {% for i in 0..60 %}
                                                    <option value="{{ i }}" {{ i == defaultValue ? 'selected' : '' }}>{{ i }}</option>
                                                {% endfor %}
                                            </select>
                                            <button class="btn" type="button" id="{{ valve.name }}_more" title="Wydłuż czas podlewania" style="width: 20px">&#8594;</button>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                            <div class="mb-3 mt-3 row">
                                <label class="col-3 col-form-label" for="hydration_start_time">Start</label>
                                <div class="col">
                                    <input type="datetime-local" class="form-control text-center" id="hydration_start_time" name="hydration_start_time" min="{{ "now"|date('Y-m-d H:i') }}"/>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-azure w-100 mt-2">Uruchom sekwencję</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-9 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Aktualny plan nawadniania</h3>
                    </div>
                    {% if hydrationPlan is not empty %}
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                <tr>
                                    <th class="w-1">Strefa</th>
                                    <th class="w-100">Progress</th>
                                    <th class="text-center">Start</th>
                                    <th class="text-center">Czas</th>
                                    <th class="text-center">Koniec</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for state in hydrationPlan %}
                                    <tr>
                                        <td class="text-nowrap">
                                            {{ state.valve|trans }}
                                        </td>
                                        <td class="text-secondary">
                                            <div class="progress">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                                     style="width: {{ state.calculateActualProgress > 0
                                                         ? (state.calculateActualProgress / state.duration) * 100
                                                         : 0
                                                     }}%"
                                                     data-start-time="{{ (state.startsAt ?? state.scheduledStartAt)|date('c') }}"
                                                     data-end-time="{{ state.scheduledEndAt ? state.scheduledEndAt|date('c') }}"
                                                     data-duration="{{ state.duration }}"
                                                     data-actual-progress="{{ state.calculateActualProgress }}"
                                                ></div>
                                            </div>
                                        </td>
                                        <td class="text-secondary text-center">
                                            {{ (state.startsAt ?? state.scheduledStartAt)|date('d.m.Y') }}
                                            {{ (state.startsAt ?? state.scheduledStartAt)|date('H:i:s') }}
                                        </td>
                                        <td class="text-secondary text-center text-nowrap">
                                                <span class="progress-text">
                                                    0%<br>
                                                    {{ (state.duration // 60) }}:{{ (state.duration % 60)|format('%02d') }}
                                                </span>
                                        </td>
                                        <td class="text-secondary text-center">
                                            {{ state.scheduledEndAt ? state.scheduledEndAt|date('H:i:s') }}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="card-body">
                            <p class="text-secondary">
                                Nie ma żadnych bieżących ani planowanych nawodnień.
                            </p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block pagejs %}
    <script src="{{ asset('js/hydration/hydration-quick-run.js') }}"></script>
    <script src="{{ asset('js/hydration/hydration-schedule.js') }}"></script>
{% endblock %}
