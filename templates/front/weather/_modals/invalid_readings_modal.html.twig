<div class="modal modal-blur fade" id="weather-invalid-readings-modal" tabindex="-1" aria-labelledby="weatherInvalidReadingsLabel"
     aria-hidden="true" data-preview-url="{{ path('app_weather_daily_invalid_readings_preview') }}"
     data-apply-url="{{ path('app_weather_daily_invalid_readings_apply') }}" data-csrf-token="{{ csrf_token('weather_invalid_readings') }}">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable" role="dialog" aria-modal="true">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="weatherInvalidReadingsLabel">Usuwanie nierealnych odczytów</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    Najpierw pokażę podejrzane odczyty dla wybranego parametru i zakresu, a dopiero potem możesz zatwierdzić wynullowanie
                    tych wartości w bazie danych.
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="weather-invalid-field">Parametr</label>
                        <select class="form-select" id="weather-invalid-field">
                            {% for field in cleanupFields %}
                                <option value="{{ field.id }}">{{ field.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="weather-invalid-from-time">Od godziny</label>
                        <input class="form-control" type="time" id="weather-invalid-from-time">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="weather-invalid-to-time">Do godziny</label>
                        <input class="form-control" type="time" id="weather-invalid-to-time">
                    </div>
                </div>
                <div class="mt-3 small text-muted">
                    Analizowany dzień: <span id="weather-invalid-date-label">{{ date|date('Y-m-d') }}</span>
                </div>
                <div class="mt-3 d-none alert alert-danger" id="weather-invalid-error"></div>
                <div class="mt-3 d-none alert alert-success" id="weather-invalid-empty"></div>
                <div class="mt-3 d-none" id="weather-invalid-summary"></div>
                <div class="mt-3 d-none table-responsive" id="weather-invalid-preview">
                    <table class="table table-vcenter card-table">
                        <thead>
                        <tr>
                            <th>Czas</th>
                            <th>Wartość</th>
                            <th>Powód</th>
                        </tr>
                        </thead>
                        <tbody id="weather-invalid-preview-body"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <div class="me-auto small text-muted" id="weather-invalid-status"></div>
                <button type="button" class="btn btn-outline-primary" id="weather-invalid-preview-btn">Pokaż podejrzane odczyty</button>
                <button type="button" class="btn btn-danger d-none" id="weather-invalid-apply-btn" disabled>Zmień na null</button>
            </div>
        </div>
    </div>
</div>
