<html lang="en" class="no-scrollbar">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
    <title>Mikusie Home Assistant</title>
    <!-- BEGIN GLOBAL MANDATORY STYLES -->
    <link href="{{ asset('css/tabler.css') }}?v=0.1" rel="stylesheet"/>
    <!-- END GLOBAL MANDATORY STYLES -->
    <!-- BEGIN PLUGINS STYLES -->
    <link href="{{ asset('css/tabler-flags.css') }}?v=0.1" rel="stylesheet"/>
    <link href="{{ asset('css/tabler-socials.css') }}?v=0.1" rel="stylesheet"/>
    <link href="{{ asset('css/tabler-payments.css') }}?v=0.1" rel="stylesheet"/>
    <link href="{{ asset('css/tabler-vendors.css') }}?v=0.1" rel="stylesheet"/>
    <link href="{{ asset('css/tabler-marketing.css') }}?v=0.1" rel="stylesheet"/>
    <link href="{{ asset('css/tabler-themes.css') }}?v=0.1" rel="stylesheet"/>
    <!-- END PLUGINS STYLES -->
    <!-- BEGIN CUSTOM FONT -->
    <style>
       @import url("{{ asset('css/inter.css') }}");

       .scene-controller-status:not(:empty) {
          margin-top: 15px;
       }
    </style>
    {% block customCss %}{% endblock %}
    <!-- END CUSTOM FONT -->
</head>
<body>
<!-- BEGIN GLOBAL THEME SCRIPT -->
<script src="{{ asset('js/tabler-theme.js') }}?v=0.1"></script>
<!-- END GLOBAL THEME SCRIPT -->
{% block page %}
<div class="page">
    <!-- BEGIN NAVBAR  -->
    {% include '_partials/_header.html.twig' %}
    {% include '_partials/_navbar.html.twig' %}
    <!-- END NAVBAR  -->
    <div class="page-wrapper">
        <!-- BEGIN PAGE HEADER -->
        <div class="page-header d-print-none" aria-label="Page header">
            <div class="container-xl">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <!-- Page pre-title -->
                        <div class="page-pretitle">{% block pagePreTitle %}Overview{% endblock %}</div>
                        <h2 class="page-title">{% block pageTitle %}Dashboard{% endblock %}</h2>
                    </div>
                    <!-- Page title actions -->
                    <div class="col-auto ms-auto d-print-none">
                        <div class="btn-list">
                            {% block pageTitleActions %}
                                <a href="#" class="btn btn-azure btn-5 d-none d-sm-inline-block" data-bs-toggle="modal" data-bs-target="#scene_modal">
                                    {{ include('_icons/scan-icon.svg.twig') }}
                                    Sceny
                                </a>
                                <a href="#" class="btn btn-azure btn-6 d-sm-none btn-icon" data-bs-toggle="modal" data-bs-target="#scene_modal">
                                    {{ include('_icons/scan-icon.svg.twig') }}
                                </a>
                            {% endblock %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- END PAGE HEADER -->
        <!-- BEGIN PAGE BODY -->
        <div class="page-body">
            {% include 'front/_partials/flashes.html.twig' %}
            {% block pageBody %}{% endblock %}
        </div>
        <!-- END PAGE BODY -->
        <!--  BEGIN FOOTER  -->
        {% include '_partials/_footer.html.twig' %}
        <!--  END FOOTER  -->
    </div>
</div>
{% endblock page %}
<!-- BEGIN GLOBAL MANDATORY SCRIPTS -->
<script src="{{ asset('js/tabler.js') }}?1751266213" defer></script>
<!-- END GLOBAL MANDATORY SCRIPTS -->
<!-- BEGIN PAGE SCRIPTS -->
<script src="{{ asset('assets/jquery-3.7.1.min.js') }}"></script>
<script src="{{ asset('libs/apexcharts/dist/apexcharts.js') }}?1751266219" defer></script>
{% block modals %}{% endblock %}
<!-- BEGIN MODAL -->
<div class="modal modal-blur fade" id="scene_modal" tabindex="-1" aria-labelledby="sceneModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-3 modal-dialog-centered" role="dialog" aria-modal="true">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sceneModalLabel">Sceny</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

            </div>
        </div>
    </div>
</div>
<!-- END MODAL -->
{% block pagejs %}{% endblock %}
<script type="text/javascript">
    $(document).ready(function() {
        $('#scene_modal').on('show.bs.modal', function (event) {
            const modalBody = $(this).find('.modal-body');
            // Opcjonalnie: wyczyść zawartość i pokaż loader
            modalBody.html('<div class="text-center p-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>');

            $.ajax({
                url: '{{ path('app_front_scene_modal') }}', // Poprawna nazwa trasy
                method: 'GET',
                success: function(response) {
                    if (response && response.modal_content) {
                        modalBody.html(response.modal_content);
                    } else {
                        modalBody.html('<div class="alert alert-danger">Błąd: Nie otrzymano zawartości modala.</div>');
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Błąd ładowania modala scen:", status, error, xhr);
                    modalBody.html('<div class="alert alert-danger">Wystąpił błąd podczas ładowania scen.</div>');
                }
            });
        });
    });
</script>
<!-- END PAGE SCRIPTS -->
</body>
</html>
